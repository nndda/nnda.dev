<section id="profile">
  <div class="bg-cover">
    <div class="section-inner">
      <div class="info-container">

        <div class="pfp-cont">
          <div class="profile-pict anim once fade float-up">
            <div class="img-cont">
              {{ img "/assets/avatar.avif" "" }}
            </div>

            <div class="status">
              <span>{{ site.authorProfile.status.icon }}</span>
              {{ site.authorProfile.status.text }}
            </div>
          </div>
        </div>

        <h1 class="author-name anim once fade float-right">
          {{ site.author }}
          <small>です~!</small>
        </h1>

        <p class="author-desc anim once fade float-up">
          {{{ site.authorProfile.description }}}
        </p>

        <ul class="author-info nostyle">
          <li class="icon-text anim once">
            {{{ icon "profile" "volume-high" 20 20 }}}
            {{{ site.authorProfile.pronunciation }}}
          </li>

          <li class="icon-text anim once">
            {{{ icon "profile" "user-tag" 20 20 }}}
            {{{ site.authorProfile.pronouns }}}
          </li>

          <li class="icon-text anim once">
            {{{icon "profile" "clock" 20 20}}}
            <span id="clock-timezone" data-timezone="{{site.authorProfile.timezone}}">
              00:00:00
            </span>
          </li>

          <li class="icon-text anim once">
            {{{ icon "profile" "location-dot" 20 20 }}}
            {{{ site.authorProfile.location }}}
            <span>
            </span>
          </li>

          <li class="icon-text anim once">
            {{{ icon "profile" "language" 20 20 }}}
            {{{ site.authorProfile.languages }}}
          </li>
        </ul>

      </div>
    </div>
  </div>
</section>

{{ script "/scripts/sections/profile.ts" true }}
