{
  "name": "nnda.dev",
  "description": "Unhingedly overengineered corner of the internet of nnda",
  "author": {
    "name": "nnda",
    "email": "talk@nnda.dev",
    "url": "https://nnda.dev"
  },
  "license": "AGPL-3.0-or-later",
  "os": [
    "linux"
  ],
  "private": true,
  "scripts": {
    "dev": "bun run start",
    "start": "bun run build:config && bun run build:data && concurrently 'webpack-dev-server --config ./config/webpack.dev.js --port 9000' 'bun run watch:data'",
    "build": "bun run build:config && bun run fetch:gh && bun run fetch:data-ext && bun run build:data && webpack --no-devtool --config ./config/webpack.config.js && bun run post:build",
    "build:data": "bun run --tsconfig-override=./config/tsconfig.build.json ./src/scripts/build/index.ts",
    "build:config": "tsc --project ./config/tsconfig.build.json",
    "watch:project": "ts-node ./src/_projects/project-pages.ts --watch",
    "watch:data": "bun run build:data -- --watching",
    "lint:styles": "stylelint --config ./config/.stylelintrc.json \"**/*.scss\"",
    "lint:scripts": "eslint --config ./config/eslint.config.ts .",
    "fetch:gh": "python ./src/api/gh.py",
    "fetch:data-ext": "python ./src/api/data-ext.py",
    "post:build": "python ./src/post/post_build.py && bun run --tsconfig-override=./config/tsconfig.build.json ./src/post/post-build.ts"
  },
  "engines": {
    "bun": "^1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-regular-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@swc/html": "^1.15.43",
    "@types/bun": "^1.3.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.1",
    "@types/webpack": "^5.28.5",
    "autoprefixer": "^10.5.2",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "cron-parser": "^5.6.1",
    "css-loader": "^7.1.4",
    "cssnano": "^8.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "html-bundler-webpack-plugin": "^4.23.2",
    "image-size": "^2.0.2",
    "lodash": "^4.18.1",
    "postcss": "^8.5.16",
    "postcss-loader": "^8.2.1",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "simple-icons": "^16.25.0",
    "style-loader": "^4.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0",
    "wrangler": "^4.108.0",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "esbuild": "^0.28.1",
    "launch-editor": "^2.14.1",
    "ws": "^8.21.0",
    "js-yaml": "^4.2.0",
    "http-proxy-middleware": "^4.1.1"
  }
}
